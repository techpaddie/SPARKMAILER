// SPARKMAILER - Prisma Schema
// License-based bulk email marketing platform

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & LICENSES
// ============================================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  name            String?
  role            UserRole  @default(USER)
  status          UserStatus @default(ACTIVE)
  machineId       String?   // Bound machine fingerprint
  licenseId       String?
  license         License?  @relation(fields: [licenseId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?

  campaigns       Campaign[]
  lists           List[]
  templates       Template[]
  smtpServers     SmtpServer[]
  auditLogs       AuditLog[]
  usageLogs       UsageLog[]
  supportTickets  SupportTicket[]
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

model License {
  id                  String        @id @default(uuid())
  licenseKey          String        @unique
  status              LicenseStatus @default(ACTIVE)
  expiresAt           DateTime
  maxEmailsPerDay     Int
  maxCampaignsPerDay  Int
  allowedIps          String[]      // JSON array of allowed IPs
  assignedEmail       String?       // Restricts activation to this email only
  boundMachineId      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  createdBy           String?
  notes               String?

  users               User[]
  usageLogs           UsageLog[]
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

// ============================================
// CAMPAIGNS & RECIPIENTS
// ============================================

model Campaign {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  subject       String
  status        CampaignStatus  @default(DRAFT)
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  totalRecipients Int           @default(0)
  sentCount     Int             @default(0)
  templateId    String?
  template      Template?       @relation(fields: [templateId], references: [id])
  listId        String
  list          List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  smtpServerId  String?
  smtpServer    SmtpServer?     @relation(fields: [smtpServerId], references: [id])
  metadata      Json?           // Extra campaign data
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  recipients    CampaignRecipient[]
  emailEvents   EmailEvent[]

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model CampaignRecipient {
  id          String    @id @default(uuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id])
  status      RecipientStatus @default(PENDING)
  sentAt      DateTime?
  error       String?
  messageId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  emailEvents EmailEvent[]

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([status])
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
  SKIPPED
}

// ============================================
// EMAIL EVENTS (Analytics)
// ============================================

model EmailEvent {
  id              String        @id @default(uuid())
  campaignId      String
  campaign        Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipientId     String?
  recipient       CampaignRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  eventType       EmailEventType
  email           String
  domain          String?
  messageId       String?
  metadata        Json?         // ip, user_agent, link_url, etc.
  createdAt       DateTime      @default(now())

  @@index([campaignId])
  @@index([eventType])
  @@index([email])
  @@index([domain])
  @@index([createdAt])
  @@index([campaignId, eventType])
}

enum EmailEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
  UNSUBSCRIBED
  SPAM
}

// ============================================
// SMTP SERVERS
// ============================================

model SmtpServer {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  host            String
  port            Int       @default(587)
  secure          Boolean   @default(false)
  username        String
  passwordEnc     String    // AES-256 encrypted
  fromEmail       String
  fromName        String?
  isActive        Boolean   @default(true)
  /// When false, server is skipped for campaign sends and rotation (tests and editing still allowed).
  bulkSendEnabled Boolean   @default(true)
  healthScore     Float     @default(100)
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  bounceCount     Int       @default(0)
  avgResponseMs   Int       @default(0)
  lastUsedAt      DateTime?
  lastHealthAt    DateTime?
  weight              Int       @default(10) // Rotation weight (relative share when healthy)
  sendDelayMs         Int       @default(0) // Extra delay after each send via this server (milliseconds)
  maxSendsPerMinute   Int       @default(0) // Cap sends per calendar minute per server (0 = unlimited)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campaigns       Campaign[]

  @@index([userId])
  @@index([isActive])
  @@index([healthScore])
}

// System SMTP for notifications (license emails, etc.) - configured in admin Settings
model SystemSmtpConfig {
  id          String   @id @default(uuid())
  host        String
  port        Int      @default(587)
  secure      Boolean  @default(false)
  username    String
  passwordEnc String
  fromEmail   String
  fromName    String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// ============================================
// TEMPLATES
// ============================================

model Template {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  subject     String?
  htmlContent String    @db.Text
  textContent String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  campaigns   Campaign[]

  @@index([userId])
}

// ============================================
// LISTS & CONTACTS
// ============================================

model List {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  contactCount Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  campaigns   Campaign[]
  contacts    Contact[]
  listTags    ListTag[]
}

model ListTag {
  id        String   @id @default(uuid())
  listId    String
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  tag       String
  createdAt DateTime @default(now())

  @@unique([listId, tag])
  @@index([listId])
  @@index([tag])
}

model Contact {
  id          String    @id @default(uuid())
  listId      String
  list        List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  email       String
  firstName   String?
  lastName    String?
  metadata    Json?     // Custom fields
  tags        String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recipients  CampaignRecipient[]

  @@unique([listId, email])
  @@index([listId])
  @@index([email])
  @@index([tags])
}

// ============================================
// SUPPRESSION & GLOBAL UNSUBSCRIBE
// ============================================

model SuppressionList {
  id        String   @id @default(uuid())
  userId    String
  email     String
  reason    String?  // bounce, spam, unsubscribe, manual
  domain    String?
  createdAt DateTime @default(now())

  @@unique([userId, email])
  @@index([userId])
  @@index([email])
  @@index([domain])
}

model GlobalUnsubscribe {
  id        String   @id @default(uuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())

  @@index([email])
}

// ============================================
// SUPPORT TICKETS
// ============================================

model SupportTicket {
  id            String                 @id @default(uuid())
  userId        String
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String
  category      String?
  priority      SupportTicketPriority  @default(MEDIUM)
  status        SupportTicketStatus    @default(OPEN)
  lastMessageAt DateTime               @default(now())
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  messages      SupportTicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([lastMessageAt])
}

model SupportTicketMessage {
  id          String               @id @default(uuid())
  ticketId     String
  ticket       SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorType   SupportMessageAuthor
  authorId     String?
  authorEmail  String?
  authorName   String?
  body         String              @db.Text
  attachments  Json?
  createdAt    DateTime            @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportMessageAuthor {
  USER
  ADMIN
}

// ============================================
// AUDIT & USAGE LOGS
// ============================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  resource  String?
  resourceId String?
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model UsageLog {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseId       String
  license         License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  emailsSent      Int      @default(0)
  campaignsRun    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, date])
  @@index([licenseId])
  @@index([date])
  @@index([userId, date])
}
