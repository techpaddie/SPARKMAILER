NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/sparkmailer
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-32-character-minimum-secret-key-here
JWT_REFRESH_SECRET=your-32-character-minimum-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
CORS_ORIGIN=http://localhost:5173
# Production example: CORS_ORIGIN=https://sparkmailer.app
PUBLIC_BASE_URL=
# Production example: PUBLIC_BASE_URL=https://sparkmailer.app
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
OPENAI_API_KEY=
BATCH_SIZE=200
SEND_RATE_PER_SECOND=10
